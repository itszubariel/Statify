{
  "name": "statify",
  "displayName": "Statify",
   "publisher": "zubariel",
  "description": "Show project statistics in sidebar",
  "version": "0.0.1",
  "icon": "images/Statify.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "stats",
    "analytics",
    "code",
    "dashboard",
    "project",
    "insights"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:statify.openDashboard"
  ],
  "contributes": {
    "commands": [
      {
        "command": "statify.openDashboard",
        "title": "Open Statify Dashboard"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/itszubariel/Statify.git"
  }
}
